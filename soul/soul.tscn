[sub_resource type="GDScript" id="GDScript_o537i"]
resource_name = "FlameEffect"
script/source = "extends AnimatedSprite2D

@export var anim: AnimationPlayer
var prev_state

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		
				
		if soulmode.dashstate != prev_state and soulmode.dashstate == soulmode.DashState.DASHING:
			anim.play(\"dash\")
		
		
		
		if soulmode.dashstate == soulmode.DashState.DASHING:
			visible = true
		else:
			visible = false

		prev_state = soulmode.dashstate
"

[sub_resource type="GDScript" id="GDScript_wv4ap"]
resource_name = "OrangeDots"
script/source = "extends Node2D

var base_offset: float = 35.0
var offset: float = 0.0

func _process(delta: float) -> void:
	if not Global.soul.current_soul_type == SoulType.ORANGE:
		return
	
	rotate(5.0 * delta)
	
	
	var soulmode = Global.soul.behaviors[0]
	
	modulate = lerp(Color(\"ffffff00\"),Color(\"ffffff\"),max(soulmode.charge_timer-2.0,0.0)/16.0)
	
	match soulmode.dashstate:

		soulmode.DashState.CHARGING:
			visible = true
			offset = lerp(base_offset,0.0,soulmode.charge_timer/16.0)
		_:
			visible = false
			
	
	var rot = 0.0
	
	
	
	for i in get_children():
		
		rot += 90.0
		print(\"ROT = \", rot)
		i.position = Vector2(0.0,offset).rotated(deg_to_rad(rot))
		i.scale = (Vector2.ONE - (Vector2.ONE * soulmode.charge_timer)/32) * 4.0
		
		i.global_rotation = 0.0
"

[sub_resource type="GDScript" id="GDScript_vqolc"]
resource_name = "HeartOutline"
script/source = "extends TextureProgressBar

func _process(delta: float) -> void:
	if not Global.soul.current_soul_type == SoulType.ORANGE:
		return
		
	var soulmode = Global.soul.behaviors[0]
	
	match soulmode.dashstate:
		soulmode.DashState.CHARGING:
			visible = true
			value = (soulmode.charge_timer)
			max_value = soulmode.charge_max
		soulmode.DashState.DASHING:
			visible = true
			value = (soulmode.dash_flash)
			max_value = (soulmode.charge_max)
		_:
			visible = false
"

[sub_resource type="GDScript" id="GDScript_p0r6y"]
resource_name = "SuperHeart"
script/source = "extends Sprite2D

var siner = 0.0

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		

		
		match soulmode.dashstate:

			
			soulmode.DashState.CHARGING:
				if soulmode.charge_timer == 16.0:
					visible = true
					siner += delta
					var alpha = 0.75 + Siner.get_sine(siner,0.5,20.0)
					print(\"ALPHA \", alpha)
					modulate.a = alpha
			
			_:
				visible = false
				siner = 0.0
		
"

[sub_resource type="GDScript" id="GDScript_72iol"]
resource_name = "SuperHeartSmall"
script/source = "extends Sprite2D

var siner = 0.0

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		
		
		match soulmode.dashstate:

			
			soulmode.DashState.DASHING:
				visible = true
				siner += delta
				var alpha = 0.5 + Siner.get_sine(siner,0.5,40.0)
				modulate.a = alpha
			
			_:
				visible = false
				siner = 0.0
		
"

[sub_resource type="GDScript" id="GDScript_t3har"]
resource_name = "Charge"
script/source = "extends AudioStreamPlayer

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		if soulmode.dashstate == soulmode.DashState.CHARGING:
			if not playing:
				playing = true
			pitch_scale = min(0.25 + (soulmode.charge_timer * 0.05),1)
			print(\"TEST\", linear_to_db(0.5))
						#snd_pitch(loop_sound, min(0.5 + (chargetimer * 0.05), 1));
		else:
			playing = false
"

