[sub_resource type="GDScript" id="GDScript_p0r6y"]
resource_name = "SuperHeart"
script/source = "extends Sprite2D

var siner = 0.0

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		var siner = 0.0
		
		match soulmode.dashstate:
			soulmode.DashState.IDLE:
				visible = false
			
			soulmode.DashState.CHARGING:
				if soulmode.charge_timer == 16.0:
					visible = true
					siner += delta
					var alpha = 0.5 + Siner.get_sine(siner,0.5,2.0)
					print(\"ALPHA \", alpha)
					modulate.a = alpha
					
			
		
"

[sub_resource type="GDScript" id="GDScript_vqolc"]
resource_name = "HeartOutline"
script/source = "extends TextureProgressBar

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		value = (soulmode.charge_timer)
		max_value = soulmode.charge_max
		print (\"VALUE \", value)
"

[sub_resource type="GDScript" id="GDScript_t3har"]
resource_name = "Charge"
script/source = "extends AudioStreamPlayer

func _process(delta: float) -> void:
	if Global.soul.current_soul_type == SoulType.ORANGE:
		var soulmode = Global.soul.behaviors[0]
		if soulmode.dashstate == soulmode.DashState.CHARGING:
			if not playing:
				playing = true
			pitch_scale = min(0.25 + (soulmode.charge_timer * 0.05),1)
			print(\"TEST\", linear_to_db(0.5))
						#snd_pitch(loop_sound, min(0.5 + (chargetimer * 0.05), 1));
		else:
			playing = false
"

