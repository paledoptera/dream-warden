; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Dream Warden"
config/description="A recreation of Deltarune's combat system in Godot (https://github.com/DevPoodle/delta-battle)"
config/tags=PackedStringArray("top_down_2d")
run/main_scene="uid://b53ljrv0fb6u4"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=30
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/stretch_mode=0
boot_splash/use_filter=false
boot_splash/image="uid://bu4shuado4hld"
config/icon="uid://boqqgdwprwmta"

[audio]

buses/default_bus_layout="uid://cnju35dvbs6uh"

[autoload]

Global="*res://globals/global/global.gd"
PostProcessing="*res://globals/post_processing/post_processing.tscn"
Sounds="*res://globals/sounds/sounds.gd"

[debug]

gdscript/warnings/unused_signal=0
gdscript/warnings/integer_division=0
gdscript/warnings/confusable_local_declaration=0

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="Delta Battle"

[file_customization]

folder_colors={
"res://fighters/characters/_/": "gray",
"res://fighters/monsters/dream_warden/attacks/laser/_res/": "gray",
"res://fighters/monsters/dream_warden/attacks/wings/_res/": "gray"
}

