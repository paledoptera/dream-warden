[sub_resource type="GDScript" id="GDScript_lu0nu"]
resource_name = "Clockhand"
script/source = "extends Sprite2D

@export var clock_speed = 4.0

func _process(delta: float) -> void:
	rotate(clock_speed*delta)
"

