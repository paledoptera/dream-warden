script/source = "extends Sprite3D

func _ready() -> void:
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(self,\"scale\",Vector3.ZERO,1.0).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_CUBIC)
	tween.tween_property(self,\"modulate\",Color(\"00ffff00\"),1.0).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_CUBIC)
"

